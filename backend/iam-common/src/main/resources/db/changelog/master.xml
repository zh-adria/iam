<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">

    <changeSet id="001-create-auth-tables" author="iam">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="auth_user"/></not></preConditions>

        <createTable tableName="auth_tenant">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="code" type="varchar(32)"><constraints nullable="false" unique="true"/></column>
            <column name="name" type="varchar(128)"><constraints nullable="false"/></column>
            <column name="isolation_mode" type="varchar(16)"><constraints nullable="false"/></column>
            <column name="schema_name" type="varchar(64)"/>
            <column name="ldap_url" type="varchar(255)"/>
            <column name="ldap_base" type="varchar(255)"/>
            <column name="enabled" type="boolean" defaultValueBoolean="true"><constraints nullable="false"/></column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <createTable tableName="auth_user">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="username" type="varchar(64)"><constraints nullable="false" unique="true"/></column>
            <column name="password_hash" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="email" type="varchar(128)"/>
            <column name="phone" type="varchar(32)"/>
            <column name="tenant_code" type="varchar(32)"><constraints nullable="false"/></column>
            <column name="status" type="int" defaultValueNumeric="1"><constraints nullable="false"/></column>
            <column name="mfa_secret" type="varchar(255)"/>
            <column name="mfa_enabled" type="boolean" defaultValueBoolean="false"><constraints nullable="false"/></column>
            <column name="fail_count" type="int" defaultValueNumeric="0"/>
            <column name="locked_until" type="timestamp"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="timestamp"/>
        </createTable>

        <createTable tableName="auth_role">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="code" type="varchar(64)"><constraints nullable="false" unique="true"/></column>
            <column name="name" type="varchar(128)"><constraints nullable="false"/></column>
            <column name="tenant_code" type="varchar(32)"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <createTable tableName="auth_permission">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="code" type="varchar(128)"><constraints nullable="false" unique="true"/></column>
            <column name="type" type="varchar(16)"><constraints nullable="false"/></column>
            <column name="name" type="varchar(128)"/>
            <column name="resource" type="varchar(255)"/>
            <column name="action" type="varchar(32)"/>
            <column name="spel_expression" type="text"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <createTable tableName="auth_user_role">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="user_id" type="bigint"><constraints nullable="false"/></column>
            <column name="role_code" type="varchar(64)"><constraints nullable="false"/></column>
            <column name="granted_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        <addUniqueConstraint tableName="auth_user_role" columnNames="user_id,role_code"/>
        <createIndex indexName="idx_ur_user" tableName="auth_user_role">
            <column name="user_id" type="bigint"/>
        </createIndex>

        <createTable tableName="auth_role_permission">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="role_code" type="varchar(64)"><constraints nullable="false"/></column>
            <column name="perm_code" type="varchar(128)"><constraints nullable="false"/></column>
            <column name="granted_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        <addUniqueConstraint tableName="auth_role_permission" columnNames="role_code,perm_code"/>

        <createTable tableName="auth_oauth2_client">
            <column name="client_id" type="varchar(64)"><constraints primaryKey="true"/></column>
            <column name="client_secret_hash" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="grant_types" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="redirect_uris" type="text"/>
            <column name="scopes" type="text"/>
            <column name="access_token_ttl_minutes" type="int" defaultValueNumeric="30"><constraints nullable="false"/></column>
            <column name="refresh_token_ttl_days" type="int" defaultValueNumeric="30"><constraints nullable="false"/></column>
            <column name="auto_approve" type="boolean" defaultValueBoolean="false"><constraints nullable="false"/></column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <createTable tableName="auth_refresh_token">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="token" type="varchar(128)"><constraints nullable="false" unique="true"/></column>
            <column name="user_id" type="bigint"><constraints nullable="false"/></column>
            <column name="tenant_code" type="varchar(32)"><constraints nullable="false"/></column>
            <column name="client_id" type="varchar(64)"><constraints nullable="false"/></column>
            <column name="scopes" type="text"><constraints nullable="false"/></column>
            <column name="expires_at" type="timestamp"><constraints nullable="false"/></column>
            <column name="issued_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="revoked_at" type="timestamp"/>
        </createTable>
        <createIndex indexName="idx_rt_token" tableName="auth_refresh_token"><column name="token" type="varchar(128)"/></createIndex>
        <createIndex indexName="idx_rt_user" tableName="auth_refresh_token"><column name="user_id" type="bigint"/></createIndex>

        <createTable tableName="auth_audit_log">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="user_id" type="bigint"/>
            <column name="tenant_code" type="varchar(32)"><constraints nullable="false"/></column>
            <column name="action" type="varchar(32)"><constraints nullable="false"/></column>
            <column name="result" type="varchar(16)"><constraints nullable="false"/></column>
            <column name="principal" type="varchar(128)"/>
            <column name="ip" type="varchar(64)"/>
            <column name="detail" type="text"/>
            <column name="occurred_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="hash_chain_prev" type="varchar(128)"/>
        </createTable>
        <createIndex indexName="idx_audit_user" tableName="auth_audit_log"><column name="user_id" type="bigint"/></createIndex>
        <createIndex indexName="idx_audit_time" tableName="auth_audit_log"><column name="occurred_at" type="timestamp"/></createIndex>

        <createTable tableName="auth_social_binding">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="user_id" type="bigint"><constraints nullable="false"/></column>
            <column name="provider" type="varchar(24)"><constraints nullable="false"/></column>
            <column name="provider_user_id" type="varchar(128)"><constraints nullable="false"/></column>
            <column name="provider_username" type="varchar(255)"/>
            <column name="bound_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        <addUniqueConstraint tableName="auth_social_binding" columnNames="provider,provider_user_id"/>
        <createIndex indexName="idx_sb_user" tableName="auth_social_binding"><column name="user_id" type="bigint"/></createIndex>

        <createTable tableName="auth_api_key">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="prefix" type="varchar(16)"><constraints nullable="false"/></column>
            <column name="key_hash" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="name" type="varchar(64)"/>
            <column name="owner" type="varchar(64)"/>
            <column name="tenant_code" type="varchar(32)" defaultValue="default"><constraints nullable="false"/></column>
            <column name="scope" type="varchar(64)"/>
            <column name="enabled" type="boolean" defaultValueBoolean="true"><constraints nullable="false"/></column>
            <column name="expires_at" type="datetime" defaultValueDate="9999-12-31T00:00:00"><constraints nullable="false"/></column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="last_used_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        <addUniqueConstraint tableName="auth_api_key" columnNames="prefix"/>
        <addUniqueConstraint tableName="auth_api_key" columnNames="key_hash"/>
    </changeSet>

    <changeSet id="002-create-saml-idp-registration" author="iam">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="auth_saml_idp_registration"/></not></preConditions>
        <createTable tableName="auth_saml_idp_registration">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="tenant_code" type="varchar(32)"><constraints nullable="false"/></column>
            <column name="registration_id" type="varchar(64)"><constraints nullable="false"/></column>
            <column name="idp_entity_id" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="idp_sso_url" type="varchar(255)"/>
            <column name="idp_metadata_url" type="varchar(255)"/>
            <column name="idp_metadata_xml" type="text"/>
            <column name="sp_entity_id" type="varchar(255)"/>
            <column name="acs_template" type="varchar(255)"/>
            <column name="enabled" type="boolean" defaultValueBoolean="true"><constraints nullable="false"/></column>
        </createTable>
        <addUniqueConstraint tableName="auth_saml_idp_registration" columnNames="tenant_code,registration_id"/>
        <createIndex indexName="idx_saml_tenant" tableName="auth_saml_idp_registration"><column name="tenant_code" type="varchar(32)"/></createIndex>
    </changeSet>

    <changeSet id="003-create-admin-system-config" author="iam">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="admin_system_config"/></not></preConditions>
        <createTable tableName="admin_system_config">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="cfg_key" type="varchar(128)"><constraints nullable="false" unique="true"/></column>
            <column name="cfg_value" type="text"><constraints nullable="false"/></column>
            <column name="cfg_type" type="varchar(16)"><constraints nullable="false"/></column>
            <column name="description" type="varchar(255)"/>
            <column name="updated_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/></column>
        </createTable>
    </changeSet>

    <changeSet id="004-seed-social-config" author="iam">
        <preConditions onFail="MARK_RAN"><tableExists tableName="admin_system_config"/></preConditions>
        <insert tableName="admin_system_config">
            <column name="cfg_key" value="iam.social.redirect-base-url"/>
            <column name="cfg_value" value="http://localhost:8080/iam/api/auth/social"/>
            <column name="cfg_type" value="string"/>
            <column name="description" value="Social login callback base URL"/>
        </insert>
        <insert tableName="admin_system_config">
            <column name="cfg_key" value="iam.social.wechat.app-id"/>
            <column name="cfg_value" value=""/>
            <column name="cfg_type" value="string"/>
            <column name="description" value="WeChat Open Platform app id"/>
        </insert>
        <insert tableName="admin_system_config">
            <column name="cfg_key" value="iam.social.wechat.app-secret"/>
            <column name="cfg_value" value=""/>
            <column name="cfg_type" value="secret"/>
            <column name="description" value="WeChat Open Platform app secret"/>
        </insert>
        <insert tableName="admin_system_config">
            <column name="cfg_key" value="iam.social.alipay.app-id"/>
            <column name="cfg_value" value=""/>
            <column name="cfg_type" value="string"/>
            <column name="description" value="Alipay app id"/>
        </insert>
        <insert tableName="admin_system_config">
            <column name="cfg_key" value="iam.social.alipay.app-private-key"/>
            <column name="cfg_value" value=""/>
            <column name="cfg_type" value="secret"/>
            <column name="description" value="Alipay RSA2 app private key"/>
        </insert>
        <insert tableName="admin_system_config">
            <column name="cfg_key" value="iam.social.alipay.alipay-public-key"/>
            <column name="cfg_value" value=""/>
            <column name="cfg_type" value="secret"/>
            <column name="description" value="Alipay RSA2 public key"/>
        </insert>
        <insert tableName="admin_system_config">
            <column name="cfg_key" value="iam.social.alipay.redirect-uri"/>
            <column name="cfg_value" value=""/>
            <column name="cfg_type" value="string"/>
            <column name="description" value="Alipay registered HTTPS callback URL"/>
        </insert>
        <insert tableName="admin_system_config">
            <column name="cfg_key" value="iam.social.qq.app-id"/>
            <column name="cfg_value" value=""/>
            <column name="cfg_type" value="string"/>
            <column name="description" value="QQ Connect app id"/>
        </insert>
        <insert tableName="admin_system_config">
            <column name="cfg_key" value="iam.social.qq.app-key"/>
            <column name="cfg_value" value=""/>
            <column name="cfg_type" value="secret"/>
            <column name="description" value="QQ Connect app key"/>
        </insert>
        <insert tableName="admin_system_config">
            <column name="cfg_key" value="iam.social.dingtalk.app-id"/>
            <column name="cfg_value" value=""/>
            <column name="cfg_type" value="string"/>
            <column name="description" value="DingTalk OAuth app id"/>
        </insert>
        <insert tableName="admin_system_config">
            <column name="cfg_key" value="iam.social.dingtalk.app-secret"/>
            <column name="cfg_value" value=""/>
            <column name="cfg_type" value="secret"/>
            <column name="description" value="DingTalk OAuth app secret"/>
        </insert>
        <insert tableName="admin_system_config">
            <column name="cfg_key" value="iam.social.wecom.corp-id"/>
            <column name="cfg_value" value=""/>
            <column name="cfg_type" value="string"/>
            <column name="description" value="WeCom corp id"/>
        </insert>
        <insert tableName="admin_system_config">
            <column name="cfg_key" value="iam.social.wecom.corp-secret"/>
            <column name="cfg_value" value=""/>
            <column name="cfg_type" value="secret"/>
            <column name="description" value="WeCom corp secret"/>
        </insert>
        <insert tableName="admin_system_config">
            <column name="cfg_key" value="iam.social.wecom.agent-id"/>
            <column name="cfg_value" value=""/>
            <column name="cfg_type" value="string"/>
            <column name="description" value="WeCom agent id"/>
        </insert>
    </changeSet>
    <changeSet id="005-add-oidc-client-fields" author="iam">
        <addColumn tableName="auth_oauth2_client">
            <column name="id_token_claims" type="text"/>
        </addColumn>
    </changeSet>

    <changeSet id="006-fix-saml-missing-columns" author="iam">
        <addColumn tableName="auth_saml_idp_registration">
            <column name="signing_cert_pem" type="text"/>
            <column name="encryption_cert_pem" type="text"/>
            <column name="name_id_format" type="varchar(128)"/>
            <column name="attribute_mapping" type="text"/>
            <column name="metadata_last_refreshed_at" type="timestamp"/>
            <column name="metadata_refresh_interval_hours" type="int" defaultValueNumeric="6"/>
        </addColumn>
    </changeSet>

    <changeSet id="007-create-ldap-group-mapping" author="iam">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="admin_ldap_group_role_mapping"/></not></preConditions>
        <createTable tableName="admin_ldap_group_role_mapping">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="tenant_code" type="varchar(32)"><constraints nullable="false"/></column>
            <column name="ldap_group_dn" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="role_code" type="varchar(64)"><constraints nullable="false"/></column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/></column>
        </createTable>
        <addUniqueConstraint tableName="admin_ldap_group_role_mapping" columnNames="tenant_code,ldap_group_dn"/>
    </changeSet>

    <changeSet id="008-create-scim-group-member" author="iam">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="auth_scim_group_member"/></not></preConditions>
        <createTable tableName="auth_scim_group_member">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="group_id" type="bigint"><constraints nullable="false"/></column>
            <column name="member_type" type="varchar(16)"><constraints nullable="false"/></column>
            <column name="user_id" type="bigint"/>
            <column name="member_value" type="varchar(128)"><constraints nullable="false"/></column>
            <column name="display_name" type="varchar(255)"/>
            <column name="tenant_code" type="varchar(32)"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        <createIndex indexName="idx_sgm_group" tableName="auth_scim_group_member"><column name="group_id" type="bigint"/></createIndex>
        <addUniqueConstraint tableName="auth_scim_group_member" columnNames="group_id,member_value"/>
    </changeSet>

    <changeSet id="009-create-scim-group" author="iam">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="auth_scim_group"/></not></preConditions>
        <createTable tableName="auth_scim_group">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="external_id" type="varchar(128)"/>
            <column name="display_name" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="members" type="text"/>
            <column name="tenant_code" type="varchar(32)"/>
        </createTable>
        <addUniqueConstraint tableName="auth_scim_group" columnNames="tenant_code,external_id"/>
    </changeSet>

    <changeSet id="010-create-scim-token" author="iam">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="auth_scim_token"/></not></preConditions>
        <createTable tableName="auth_scim_token">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="name" type="varchar(64)"><constraints nullable="false"/></column>
            <column name="token_hash" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="token_prefix" type="varchar(16)"><constraints nullable="false"/></column>
            <column name="tenant_code" type="varchar(32)"/>
            <column name="scope" type="varchar(255)"/>
            <column name="enabled" type="boolean" defaultValueBoolean="true"><constraints nullable="false"/></column>
            <column name="expires_at" type="timestamp"><constraints nullable="false"/></column>
            <column name="last_used_at" type="timestamp"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/></column>
        </createTable>
        <addUniqueConstraint tableName="auth_scim_token" columnNames="token_prefix"/>
    </changeSet>
</databaseChangeLog>
