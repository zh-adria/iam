# IAM Platform — Docker Compose environment variables
# Copy this file to .env and fill in your values before running docker compose.

# Required: decryption key for ENC() values in application.yml
IAM_CONFIG_KEY=change-me-to-a-random-32-char-key

# Database (defaults point to a local MySQL container started by docker-compose)
# To use the remote mysql6.sqlpub.com, leave DB_HOST as default or set explicitly.
DB_HOST=mysql6.sqlpub.com
DB_PORT=3311
DB_NAME=dev_2026
DB_USER=dev_2026
DB_PASS=uF5RbUeRzGxb9qgG

# Redis
REDIS_PASS=
